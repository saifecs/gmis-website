@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --primary: #1f5d3b;
  --primary-dark: #123524;
  --concrete: #5a5a5a;
  --sand: #c8a96a;
  --white: #ffffff;
  --neutral-50: #f5f5f5;
  --neutral-100: #eaeaea;
  --neutral-900: #1a1a1a;
}

html {
  scroll-behavior: smooth;
}

body {
  @apply bg-white text-neutral-900 antialiased;
}